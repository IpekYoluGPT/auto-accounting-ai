# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# Time zone used for monthly Google Sheets rollover and dated exports
BUSINESS_TIMEZONE=Europe/Istanbul

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Token used to verify the webhook during Meta setup
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Permanent access token from Meta Developer Portal
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Phone Number ID from Meta Business / WhatsApp Cloud API dashboard
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Keep intake disabled for direct 1:1 chats; only official group messages are processed
WHATSAPP_GROUPS_ONLY=true

# ─── Periskope ────────────────────────────────────────────────────────────────
# API key from Periskope Settings > API
PERISKOPE_API_KEY=

# Org phone number or phone_id used in the x-phone header, e.g. 905551112233
PERISKOPE_PHONE=

# REST API base URL for Periskope
PERISKOPE_API_BASE_URL=https://api.periskope.app/v1

# Base URL used to resolve relative media paths from Periskope webhooks
PERISKOPE_MEDIA_BASE_URL=https://api.periskope.app

# Signing key from Settings > Webhooks for verifying x-periskope-signature
PERISKOPE_SIGNING_KEY=

# Shared token to protect your custom tool endpoints
PERISKOPE_TOOL_TOKEN=

# Comma-separated group/chat allowlist. Empty rejects all Periskope chats by design.
PERISKOPE_ALLOWED_CHAT_IDS=

# ─── Google Gemini API ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CLASSIFIER_MODEL=gemini-3.1-pro-preview
GEMINI_EXTRACTOR_MODEL=gemini-3.1-pro-preview
GEMINI_VALIDATION_MODEL=gemini-3.1-pro-preview

# ─── Google Sheets / Drive projection ─────────────────────────────────────────
# Base64-encoded service account JSON with Sheets/Drive access
GOOGLE_SERVICE_ACCOUNT_JSON=

# Current month's spreadsheet seed (optional if the registry or OAuth flow will create/open it)
GOOGLE_SHEETS_SPREADSHEET_ID=

# Parent Drive folder for monthly workbook placement and uploaded documents
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Google account email to share newly created spreadsheets with
GOOGLE_SHEETS_OWNER_EMAIL=

# OAuth bootstrap values for user-owned monthly spreadsheet/folder creation
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ─── Google Document AI OCR ───────────────────────────────────────────────────
# Uses the same service account JSON as Google Sheets/Drive.
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENT_AI_LOCATION=eu
# Preferred env var names used by the app:
GOOGLE_DOCUMENT_AI_FORM_PROCESSOR_ID=your_form_parser_processor_id
GOOGLE_DOCUMENT_AI_OCR_PROCESSOR_ID=your_enterprise_ocr_processor_id
# Short aliases are also accepted for hosts with env-name length limits:
# GOOGLE_DOCUMENT_AI_FOR_PROCESSOR=your_form_parser_processor_id
# GOOGLE_DOCUMENT_AI_OCR_PROCESSOR=your_document_ocr_processor_id
OCR_MIN_TEXT_CHARS=60
OCR_MIN_PARSE_SCORE=0.72
OCR_MIN_QUALITY_SCORE=0.45

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory for temporary media files, exports, and processed-message state
STORAGE_DIR=./storage

# Optional manager phone number for text-driven elden odeme intake
MANAGER_PHONE_NUMBER=

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
