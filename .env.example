# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# Time zone used for monthly Google Sheets rollover and dated exports
BUSINESS_TIMEZONE=Europe/Istanbul

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Token used to verify the webhook during Meta setup
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Permanent access token from Meta Developer Portal
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Phone Number ID from Meta Business / WhatsApp Cloud API dashboard
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Keep intake disabled for direct 1:1 chats; only official group messages are processed
WHATSAPP_GROUPS_ONLY=true

# ─── Periskope ────────────────────────────────────────────────────────────────
# API key from Periskope Settings > API
PERISKOPE_API_KEY=

# Org phone number or phone_id used in the x-phone header, e.g. 905551112233
PERISKOPE_PHONE=

# REST API base URL for Periskope
PERISKOPE_API_BASE_URL=https://api.periskope.app/v1

# Base URL used to resolve relative media paths from Periskope webhooks
PERISKOPE_MEDIA_BASE_URL=https://api.periskope.app

# Signing key from Settings > Webhooks for verifying x-periskope-signature
PERISKOPE_SIGNING_KEY=

# Shared token to protect your custom tool endpoints
PERISKOPE_TOOL_TOKEN=

# ─── Google Gemini API ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CLASSIFIER_MODEL=gemini-flash-lite-latest
GEMINI_EXTRACTOR_MODEL=gemini-flash-lite-latest

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory for temporary media files, exports, and processed-message state
STORAGE_DIR=./storage

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
